{
  "name": "@bobmaertz/bitbucket-core",
  "version": "0.0.1",
  "description": "Shared core (config, logging, presenters, operations) for the Bitbucket MCP server and CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "refresh-spec": "node scripts/refresh-spec.mjs"
  },
  "keywords": [
    "bitbucket",
    "mcp",
    "core"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@bobmaertz/bitbucket-api": "file:../bitbucket-api"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
