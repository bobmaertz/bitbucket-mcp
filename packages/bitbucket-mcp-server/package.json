{
  "name": "@bobmaertz/bitbucket-mcp",
  "version": "0.0.2",
  "description": "Model Context Protocol server for Bitbucket Cloud (read-only)",
  "type": "module",
  "bin": {
    "bitbucket-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobmaertz/bitbucket-mcp.git",
    "directory": "packages/bitbucket-mcp-server"
  },
  "homepage": "https://github.com/bobmaertz/bitbucket-mcp#readme",
  "bugs": {
    "url": "https://github.com/bobmaertz/bitbucket-mcp/issues"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bitbucket",
    "llm",
    "ai"
  ],
  "author": "Bob Maertz",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@bobmaertz/bitbucket-api": "file:../bitbucket-api",
    "@bobmaertz/bitbucket-core": "file:../bitbucket-core",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
