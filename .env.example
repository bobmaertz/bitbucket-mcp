# Bitbucket MCP Server Configuration

# Required: Your Bitbucket workspace ID (find in your workspace URL)
BITBUCKET_WORKSPACE=your-workspace

# Auth precedence: access token (Bearer) > email + API token (Basic) >
# username + app password (Basic). Set exactly one scheme.

# Recommended for shared/automated use: a workspace, project, or repository
# Access Token (Bearer auth). Resource-scoped, with Bitbucket's scaled rate
# limits (up to 10,000 req/hr). Create one in the workspace/repo settings under
# "Access tokens". If set, it takes precedence over the pairs below.
# BITBUCKET_ACCESS_TOKEN=your-access-token

# Atlassian API token auth (Basic). The username is your Atlassian account EMAIL
# (not your Bitbucket username), and the secret is an API token created (with
# scopes) at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
BITBUCKET_EMAIL=you@example.com
BITBUCKET_API_TOKEN=your-api-token

# Deprecated fallback: username + app password.
# Atlassian disabled new app passwords (Sep 2025) and removes them entirely in
# 2026. Prefer BITBUCKET_EMAIL + BITBUCKET_API_TOKEN above. If both are set, the
# API-token pair wins.
# BITBUCKET_USERNAME=your-username
# BITBUCKET_APP_PASSWORD=your-app-password

# Optional: Logging level (debug, info, warn, error). Default: info
LOG_LEVEL=info

# Optional: Allow write operations (e.g. cutting a tag). Default: false.
# The current tool surface is read-only; this gates future write tools.
# BITBUCKET_ALLOW_WRITES=false
