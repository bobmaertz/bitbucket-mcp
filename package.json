{
  "name": "@bobmaertz/bitbucket-mcp-monorepo",
  "version": "0.0.1",
  "description": "Model Context Protocol server for Bitbucket Cloud REST API",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:contract": "npm run test:contract --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "security:check": "bash scripts/check-no-secrets.sh",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bitbucket",
    "bitbucket-api",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
